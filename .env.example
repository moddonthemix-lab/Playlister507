# ── Spotify App credentials ──────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Set Redirect URI to: http://127.0.0.1:8888/callback
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── Filled automatically by `npm run auth` ────────────────────────────────────
SPOTIFY_REFRESH_TOKEN=

# ── Optional: include your own artist(s) in The Slept On Underground ─────────
# Comma-separated artist names exactly as they appear on Spotify
OWN_ARTIST_NAMES=

# ── Schedule (cron syntax) — default: every other Monday at 9 AM ─────────────
# "0 9 * * 1" = every Monday 9am  |  biweekly is handled in code via week counter
CRON_SCHEDULE=0 9 * * 1

# ── YouTube Data API v3 ───────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
